<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — NexusCore" : "NexusCore")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <style>
        :root {
            --sidebar-width: 240px;
            --brand-blue: #2563eb;
        }
        body { background: #f8fafc; }
        .sidebar {
            position: fixed; top: 0; left: 0; bottom: 0;
            width: var(--sidebar-width);
            background: #1e293b;
            display: flex; flex-direction: column;
            z-index: 100;
        }
        .sidebar-brand {
            padding: 20px 20px 16px;
            border-bottom: 1px solid #334155;
        }
        .sidebar-brand h1 {
            font-size: 1.1rem; font-weight: 700; color: #fff; margin: 0;
            letter-spacing: -0.3px;
        }
        .sidebar-brand p { font-size: .72rem; color: #94a3b8; margin: 2px 0 0; }
        .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; }
        .sidebar-nav .nav-item a {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 20px; color: #94a3b8;
            text-decoration: none; font-size: .875rem;
            border-left: 3px solid transparent;
            transition: all .15s;
        }
        .sidebar-nav .nav-item a:hover,
        .sidebar-nav .nav-item a.active {
            color: #fff; background: rgba(255,255,255,.05);
            border-left-color: var(--brand-blue);
        }
        .sidebar-nav .nav-item a i { font-size: 1rem; }
        .sidebar-footer {
            padding: 16px 20px;
            border-top: 1px solid #334155;
        }
        .sidebar-footer .user-name { font-size: .875rem; color: #e2e8f0; font-weight: 500; }
        .sidebar-footer .user-org { font-size: .75rem; color: #64748b; }
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            padding: 32px;
        }
        .page-header { margin-bottom: 24px; }
        .page-header h2 { font-size: 1.5rem; font-weight: 700; color: #1e293b; margin: 0; }
        .page-header p { font-size: .875rem; color: #64748b; margin: 4px 0 0; }
        .card { border: 1px solid #e2e8f0; border-radius: 12px; }
        .card-header { background: #fff; border-bottom: 1px solid #f1f5f9; border-radius: 12px 12px 0 0 !important; padding: 16px 20px; }
        .badge-superadmin { background: #7c3aed; color: #fff; }
        .badge-org_manager { background: #2563eb; color: #fff; }
        .badge-asset_manager { background: #0891b2; color: #fff; }
        .badge-viewer { background: #64748b; color: #fff; }
        .badge-available { background: #16a34a; color: #fff; }
        .badge-in_use { background: #2563eb; color: #fff; }
        .badge-maintenance { background: #d97706; color: #fff; }
        .badge-retired { background: #dc2626; color: #fff; }
        .badge-active { background: #16a34a; color: #fff; }
        .badge-pending { background: #d97706; color: #fff; }
        .badge-rejected { background: #dc2626; color: #fff; }
        .table > :not(caption) > * > * { padding: .75rem 1rem; vertical-align: middle; }
        .btn-primary { background: var(--brand-blue); border-color: var(--brand-blue); }
        .btn-primary:hover { background: #1d4ed8; border-color: #1d4ed8; }
    </style>
</head>
<body>
@{
    var currentPath = Context.Request.Path.Value ?? "/";
    var userName = User.FindFirst("name")?.Value ?? User.FindFirst("email")?.Value ?? "User";
    var userOrg = User.FindFirst("org") != null ? "Organization" : "";
    var userRoleClaim = User.FindFirst("role")?.Value ?? "";
    var isOrgManager = userRoleClaim is "ORG_MANAGER" or "SUPERADMIN";
}
<div class="sidebar">
    <div class="sidebar-brand">
        <h1><i class="bi bi-hexagon-fill text-primary me-1"></i> NexusCore</h1>
        <p>Resource Management</p>
    </div>
    <nav class="sidebar-nav">
        <ul class="nav flex-column list-unstyled mb-0">
            <li class="nav-item">
                <a href="/Dashboard" class="@(currentPath.StartsWith("/Dashboard") ? "active" : "")">
                    <i class="bi bi-grid-1x2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a href="/Assets" class="@(currentPath.StartsWith("/Assets") ? "active" : "")">
                    <i class="bi bi-box-seam"></i> Assets
                </a>
            </li>
            <li class="nav-item">
                <a href="/Reports" class="@(currentPath.StartsWith("/Reports") ? "active" : "")">
                    <i class="bi bi-bar-chart-line"></i> Reports
                </a>
            </li>
            @if (isOrgManager)
            {
                <li class="nav-item">
                    <a href="/Team" class="@(currentPath.StartsWith("/Team") ? "active" : "")">
                        <i class="bi bi-people"></i> Team
                    </a>
                </li>
            }
        </ul>
    </nav>
    <div class="sidebar-footer">
        <div class="user-name text-truncate">@userName</div>
        <div class="d-flex align-items-center justify-content-between mt-2">
            <span class="badge badge-@userRoleClaim.ToLower().Replace("_", "_") rounded-pill" style="font-size:.7rem;">
                @userRoleClaim.Replace("_", " ")
            </span>
            <form method="post" action="/Logout" class="m-0">
                <button type="submit" class="btn btn-sm btn-link text-secondary p-0" style="font-size:.75rem;">
                    <i class="bi bi-box-arrow-right"></i> Sign out
                </button>
            </form>
        </div>
    </div>
</div>

<div class="main-content">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
