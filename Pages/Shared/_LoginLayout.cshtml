<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — NexusCore" : "NexusCore")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <style>
        body {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
        }
        .auth-card {
            width: 100%; max-width: 420px;
            background: #fff; border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,.3);
            padding: 40px;
        }
        .auth-brand h1 {
            font-size: 1.4rem; font-weight: 700;
            color: #1e293b; letter-spacing: -0.3px;
        }
        .auth-brand p { font-size: .875rem; color: #64748b; }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-brand text-center mb-4">
            <h1><i class="bi bi-hexagon-fill text-primary me-1"></i> NexusCore</h1>
            <p>Resource Management SaaS</p>
        </div>
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
