@page
@model NexusCoreDotNet.Pages.LoginModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Sign In";
}

<h5 class="fw-semibold text-center mb-1">Welcome back</h5>
<p class="text-muted text-center mb-4" style="font-size:.875rem;">Sign in with your Google account to continue</p>

<div id="error-box" class="alert alert-danger d-none mb-3" role="alert"></div>

@* Hidden antiforgery token readable by JS *@
<input type="hidden" id="af-token" value="@Antiforgery.GetAndStoreTokens(HttpContext).RequestToken" />

<button id="google-btn" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2 py-2 mb-3">
    <svg width="18" height="18" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>
    Sign in with Google
</button>

<div class="text-center">
    <small class="text-muted">Don't have an organization?
        <a href="/Onboarding" class="text-primary text-decoration-none fw-medium">Register here</a>
    </small>
</div>

@section Scripts {
<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.14.0/firebase-app.js";
    import { getAuth, signInWithRedirect, getRedirectResult, GoogleAuthProvider } from "https://www.gstatic.com/firebasejs/10.14.0/firebase-auth.js";

    const firebaseConfig = @Html.Raw(Model.FirebaseConfigJson);
    console.log("[login] firebaseConfig:", JSON.stringify({...firebaseConfig, apiKey: firebaseConfig.apiKey ? "[present, length=" + firebaseConfig.apiKey.length + "]" : "[MISSING]"}));
    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);
    const provider = new GoogleAuthProvider();

    const btn = document.getElementById("google-btn");
    const errBox = document.getElementById("error-box");
    const afToken = document.getElementById("af-token").value;

    async function verifyWithServer(idToken) {
        console.log("[login] af-token present:", !!afToken, "length:", afToken?.length);
        console.log("[login] posting to /Login?handler=Verify");
        const resp = await fetch("/Login?handler=Verify", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "RequestVerificationToken": afToken
            },
            body: JSON.stringify({ idToken })
        });
        console.log("[login] verify response status:", resp.status);
        const raw = await resp.text();
        console.log("[login] verify response body:", raw.substring(0, 500));
        let data;
        try { data = JSON.parse(raw); } catch { data = { error: `Non-JSON response (${resp.status}): ${raw.substring(0, 200)}` }; }
        if (data.redirect) {
            console.log("[login] redirecting to:", data.redirect);
            window.location.href = data.redirect;
        } else {
            errBox.textContent = data.error ?? "Authentication failed";
            errBox.classList.remove("d-none");
            btn.disabled = false;
            btn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg> Sign in with Google`;
        }
    }

    // On page load, check if we're returning from a redirect sign-in
    getRedirectResult(auth).then(async result => {
        console.log("[login] getRedirectResult:", result ? "GOT RESULT uid=" + result.user.uid : "null (no pending redirect)");
        if (!result) return; // no redirect in progress
        btn.disabled = true;
        btn.textContent = "Signing in...";
        const idToken = await result.user.getIdToken();
        await verifyWithServer(idToken);
    }).catch(err => {
        errBox.textContent = err.message ?? "Sign-in failed";
        errBox.classList.remove("d-none");
    });

    btn.addEventListener("click", () => {
        btn.disabled = true;
        btn.textContent = "Redirecting...";
        signInWithRedirect(auth, provider);
    });
</script>
}
