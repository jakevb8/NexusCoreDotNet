@page
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Pending Approval";
}

<div class="text-center">
    <div class="mb-4">
        <i class="bi bi-hourglass-split text-warning" style="font-size:3rem;"></i>
    </div>
    <h5 class="fw-semibold mb-2">Your organization is pending approval</h5>
    <p class="text-muted mb-4" style="font-size:.875rem;">
        A NexusCoreDotNet admin will review your registration shortly. 
        You'll receive access once your organization is approved.
    </p>
    <div class="alert alert-info text-start" style="font-size:.85rem;">
        <strong>What happens next?</strong><br/>
        Our team reviews new organizations to prevent misuse. Most approvals happen within 24 hours.
        If you need faster access, contact support.
    </div>
    <form method="post" action="/Logout" class="mt-3">
        <button type="submit" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-box-arrow-right me-1"></i>Sign out
        </button>
    </form>
</div>
