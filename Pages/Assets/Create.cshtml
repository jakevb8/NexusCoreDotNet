@page
@model NexusCoreDotNet.Pages.Assets.CreateModel
@{
    ViewData["Title"] = "Add Asset";
}

<div class="page-header">
    <h2>Add Asset</h2>
    <p>Create a new asset for your organization</p>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger mb-3">@Model.ErrorMessage</div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label for="Name" class="form-label fw-medium" style="font-size:.875rem;">Name <span class="text-danger">*</span></label>
                        <input id="Name" name="Name" class="form-control" value="@Model.Name" required placeholder="e.g. MacBook Pro"/>
                    </div>
                    <div class="mb-3">
                        <label for="SKU" class="form-label fw-medium" style="font-size:.875rem;">SKU <span class="text-danger">*</span></label>
                        <input id="SKU" name="SKU" class="form-control" value="@Model.SKU" required placeholder="e.g. MBP-2024-001"/>
                        <div class="form-text">Unique identifier for this asset.</div>
                    </div>
                    <div class="mb-3">
                        <label for="Description" class="form-label fw-medium" style="font-size:.875rem;">Description</label>
                        <textarea id="Description" name="Description" class="form-control" rows="3" placeholder="Optional description">@Model.Description</textarea>
                    </div>
                    <div class="mb-3">
                        <label for="Status" class="form-label fw-medium" style="font-size:.875rem;">Status</label>
                        <select id="Status" name="Status" class="form-select">
                            @foreach (var s in Enum.GetValues<NexusCoreDotNet.Enums.AssetStatus>())
                            {
                                <option value="@s" selected="@(s == Model.Status)">@s.ToString().Replace("_", " ")</option>
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label for="AssignedTo" class="form-label fw-medium" style="font-size:.875rem;">Assigned To</label>
                        <input id="AssignedTo" name="AssignedTo" class="form-control" value="@Model.AssignedTo" placeholder="User ID or name (optional)"/>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus me-1"></i>Create Asset
                        </button>
                        <a href="/Assets" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
