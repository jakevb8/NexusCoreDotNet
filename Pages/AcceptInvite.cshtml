@page
@model NexusCoreDotNet.Pages.AcceptInviteModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Accept Invitation";
}

@if (Model.AlreadyAccepted)
{
    <div class="text-center">
        <i class="bi bi-check-circle-fill text-success mb-3" style="font-size:3rem;display:block;"></i>
        <h5 class="fw-semibold mb-2">Invitation already accepted</h5>
        <p class="text-muted mb-3" style="font-size:.875rem;">This invite has already been used.</p>
        <a href="/Login" class="btn btn-primary">Go to Login</a>
    </div>
}
else if (Model.Expired)
{
    <div class="text-center">
        <i class="bi bi-x-circle-fill text-danger mb-3" style="font-size:3rem;display:block;"></i>
        <h5 class="fw-semibold mb-2">Invitation expired</h5>
        <p class="text-muted mb-3" style="font-size:.875rem;">This invite link has expired. Ask your organization manager to send a new invite.</p>
    </div>
}
else if (Model.InviteValid)
{
    <h5 class="fw-semibold text-center mb-1">Accept your invitation</h5>
    <p class="text-muted text-center mb-4" style="font-size:.875rem;">
        You've been invited to join <strong>@Model.OrgName</strong> as <span class="badge bg-primary">@Model.InviteRole</span>
    </p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger mb-3">@Model.ErrorMessage</div>
    }

    <div id="error-box" class="alert alert-danger d-none mb-3"></div>

    <button id="google-btn" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2 py-2 mb-3">
        <svg width="18" height="18" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Sign in with Google to Accept
    </button>
}
else
{
    <div class="text-center">
        <i class="bi bi-question-circle-fill text-secondary mb-3" style="font-size:3rem;display:block;"></i>
        <h5 class="fw-semibold mb-2">Invalid invitation</h5>
        <p class="text-muted" style="font-size:.875rem;">This invite link is not valid or has already been used.</p>
    </div>
}

@section Scripts {
@if (Model.InviteValid && !Model.AlreadyAccepted && !Model.Expired)
{
<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.14.0/firebase-app.js";
    import { getAuth, signInWithPopup, GoogleAuthProvider } from "https://www.gstatic.com/firebasejs/10.14.0/firebase-auth.js";

    const firebaseConfig = @Html.Raw(Model.FirebaseConfigJson);
    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);
    const provider = new GoogleAuthProvider();
    const token = "@Model.Token";

    document.getElementById("google-btn").addEventListener("click", async () => {
        const btn = document.getElementById("google-btn");
        const errBox = document.getElementById("error-box");
        btn.disabled = true;
        btn.textContent = "Signing in...";

        try {
            const result = await signInWithPopup(auth, provider);
            const idToken = await result.user.getIdToken();

            const resp = await fetch("/AcceptInvite?handler=Accept", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ idToken, token, displayName: result.user.displayName })
            });

            const data = await resp.json();
            if (data.redirect) {
                window.location.href = data.redirect;
            } else {
                errBox.textContent = data.error ?? "Failed to accept invite";
                errBox.classList.remove("d-none");
                btn.disabled = false;
                btn.textContent = "Sign in with Google to Accept";
            }
        } catch (err) {
            errBox.textContent = err.message;
            errBox.classList.remove("d-none");
            btn.disabled = false;
            btn.textContent = "Sign in with Google to Accept";
        }
    });
</script>
}
}
